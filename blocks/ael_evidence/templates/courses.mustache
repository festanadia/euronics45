

<!-- Slider main container -->
<div class="swiper ael_evidence_carousel">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper ">
    <!-- Slides -->
                    {{#courses}}
                 <div class="swiper-slide h-100">
                            <div class='row h-100'>

                                <div class='col-md-12 col-lg-6 ael_evidence-container-data'>

                                            <div class='ael_evidence-category'>{{coursecategory}}</div>
                                            <div class='ael_evidence-title'><a href='{{viewurl}}'>{{fullname}}</a></div>
                                            <div class='ael_evidence-desc'>{{{summary}}}</div>
                                </div>
                            

                            </div>
                 </div>   
                    {{/courses}} 
               
                   
      
  </div>
<div class="swiper-pagination swiper-pagination-ael_evidence"></div>
</div>

  

<script type="module">
 import Swiper from 'https://unpkg.com/swiper@7/swiper-bundle.esm.browser.min.js'

const swiper = new Swiper('.ael_evidence_carousel', {
  loop: false,
  slidesPerView:1,
  spaceBetween: 20,
  centeredSlides:false,

  pagination: {
    el: '.swiper-pagination',
    type: 'bullets',
    clickable:true,
    dynamicBullets:false,
    dynamicMainBullets:1
      

  },

});
</script>