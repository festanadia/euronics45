<!-- Slider main container -->

  {{^nocourse}}
    <div class="text-center d-flex align-items-center justify-content-center w-100 flex-column">
      <img src="{{config.wwwroot}}/blocks/aelchosenbyyou/pix/smile-light.png" class="ael_smile_light" />
      <h3 class="style_header">{{language.nocourses}}</h3>
    </div>
  {{/nocourse}}
<div class="swiper ael_chosenbyyou_carousel {{^nocourse}} d-none {{/nocourse}}">
  <!-- Additional required wrapper -->

  <div class="swiper-wrapper ">
    <!-- Slides -->
         {{#courses}}
                    <div class="swiper-slide">{{> block_aelchosenbyyou/components/card-course }}</div>    
          {{/courses}}
        
  </div>

  <div class="swiper-pagination swiper-pagination_chosenbyyou_carousel"></div>


</div>

  

<script type="module">
 import Swiper from 'https://unpkg.com/swiper@7/swiper-bundle.esm.browser.min.js'

const swiper = new Swiper('.ael_chosenbyyou_carousel', {
  loop: false,
  slidesPerView:3,
  spaceBetween: 20,
  centeredSlides:false,

breakpoints: {
    320: {
      slidesPerView: 1,
    },
   
    480: {
      slidesPerView: 2,
      spaceBetween: 30,
     
    },
   
    970: {
      slidesPerView: 3,
      spaceBetween: 40,
       
    },
    1170: {
      slidesPerView: 4,
      spaceBetween: 10,
    
    }
   
  },
  pagination: {
    el: '.swiper-pagination_chosenbyyou_carousel',
    type: 'bullets',
    clickable:true,
    dynamicBullets:false,
    dynamicMainBullets:1
      

  },

  // Navigation arrows
 /* navigation: {
    nextEl: '.swiper-button-next',
    prevEl: '.swiper-button-prev',
  }*/
});
</script>
