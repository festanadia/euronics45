<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/ael_gamification/db" VERSION="20120523" COMMENT="XMLDB file for Moodle mod/avatar"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="block_ael_gamification_avatar" COMMENT="Table for Moodle-block_avatar ael_gamification" >
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="true"  NEXT="userid"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" COMMENT="id user session"   NEXT="data"/>
        <FIELD NAME="data" TYPE="char" LENGTH="300" NOTNULL="true" SEQUENCE="false" COMMENT="Username linked to Avatar" PREVIOUS="userid" />
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>