            </div>
            <div class='ael_gamification-filter-badge' data-value='facialhair'>
                 {{#str}} facialhair, block_ael_gamification {{/str}}
            </div>
            <div class='ael_gamification-filter-badge' data-value='facialhaircolor'>
                 {{#str}} facialhaircolor, block_ael_gamification {{/str}}
            </div>
              <div class='ael_gamification-filter-badge' data-value='clothes'>
                 {{#str}} clothes, block_ael_gamification {{/str}}
            </div>
           <div class='ael_gamification-filter-badge' data-value='eyes'>
                 {{#str}} eyes, block_ael_gamification {{/str}}
            </div>
           <div class='ael_gamification-filter-badge' data-value='clothes'>
                 {{#str}} clothes, block_ael_gamification {{/str}}
            </div>
           <div class='ael_gamification-filter-badge' data-value='eyebrow'>
                 {{#str}} eyebrow, block_ael_gamification {{/str}}
            </div>
           <div class='ael_gamification-filter-badge' data-value='mouth'>
                 {{#str}} mouth, block_ael_gamification {{/str}}
            </div>
           <div class='ael_gamification-filter-badge' data-value='skin'>
                 {{#str}} skin, block_ael_gamification {{/str}}
            </div>
        </div>


        <div class="w-100">
            {{> block_ael_gamification/filters/typeTop }}
            {{> block_ael_gamification/filters/accessories }}
            {{> block_ael_gamification/filters/haircolor }}
            {{> block_ael_gamification/filters/facialhair }}    
            {{> block_ael_gamification/filters/facialhaircolor }}    
