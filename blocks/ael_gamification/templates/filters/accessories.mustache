<div class="ael_gamification-filter ael_gamification-filter-accessories  w-100">
   <div class="swiper ael_gamification_avatar_elements ael_gamification-swiper-accessories">
      <div class="swiper-wrapper">
         <!-- Slides -->
         <div class="swiper-slide ael_gamification_data_filter" data-value="Blank">   {{#str}} Blank, block_ael_gamification {{/str}} </div>
         
          <div class="swiper-slide ael_gamification_data_filter" data-value="Kurt">   {{#str}} Kurt, block_ael_gamification {{/str}} </div>

         <div class="swiper-slide ael_gamification_data_filter" data-value="Prescription01">   {{#str}} Prescription01, block_ael_gamification {{/str}} </div>

         <div class="swiper-slide ael_gamification_data_filter" data-value="Prescription02">   {{#str}} Prescription02, block_ael_gamification {{/str}} </div>

         <div class="swiper-slide ael_gamification_data_filter" data-value="Round">   {{#str}} Round, block_ael_gamification {{/str}} </div>

         <div class="swiper-slide ael_gamification_data_filter" data-value="Sunglasses">   {{#str}} Sunglasses, block_ael_gamification {{/str}} </div>

         <div class="swiper-slide ael_gamification_data_filter" data-value="Wayfarers">   {{#str}} Wayfarers, block_ael_gamification {{/str}} </div>

       
      </div>
   </div>
   <div class="swiper-button-prev swiper-button-prev-ael_gamification-swiper-accessories"></div>
   <div class="swiper-button-next swiper-button-next-ael_gamification-swiper-accessories"></div>
</div>


{{#js}}
require(
[
    'jquery',
    'block_ael_gamification/avatar'
],
function(
    $,
    Avatar
) {

    Avatar.initSlider('ael_gamification-swiper-accessories');
});
{{/js}}


