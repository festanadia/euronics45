



<div class="ael_gamification-filter ael_gamification-filter-eyebrow  w-100">
   <div class="swiper ael_gamification_avatar_elements ael_gamification-swiper-eyebrow">
      <div class="swiper-wrapper">
         <!-- Slides -->
         <div class="swiper-slide ael_gamification_data_filter" data-value="Default">   {{#str}} Default, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="Angry">   {{#str}} Angry, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="AngryNatural">   {{#str}} AngryNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="DefaultNatural">   {{#str}} DefaultNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="FlatNatural">   {{#str}} FlatNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="RaisedExcited">   {{#str}} RaisedExcited, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="RaisedExcitedNatural">   {{#str}} RaisedExcitedNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="SadConcerned">   {{#str}} SadConcerned, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="SadConcernedNatural">   {{#str}} SadConcernedNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="UnibrowNatural">   {{#str}} UnibrowNatural, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="UpDown">   {{#str}} UpDown, block_ael_gamification {{/str}} </div>

       


      </div>
   </div>
   <div class="swiper-button-prev swiper-button-prev-ael_gamification-swiper-eyebrow"></div>
   <div class="swiper-button-next swiper-button-next-ael_gamification-swiper-eyebrow"></div>
</div>


{{#js}}
require(
[
    'jquery',
    'block_ael_gamification/avatar'
],
function(
    $,
    Avatar
) {

    Avatar.initSlider('ael_gamification-swiper-eyebrow');
});
{{/js}}


