         <div class="swiper-slide ael_gamification_data_filter" data-value="Black">   {{#str}} Black, block_ael_gamification {{/str}} </div>
          <div class="swiper-slide ael_gamification_data_filter" data-value="Blonde">   {{#str}} Blonde, block_ael_gamification {{/str}} </div>
