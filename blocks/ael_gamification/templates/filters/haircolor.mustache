         <div class="swiper-slide ael_gamification_data_filter" data-value="Red">   {{#str}} Red, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="SilverGray">   {{#str}} SilverGray, block_ael_gamification {{/str}} </div>
      
       
      </div>
   </div>
   <div class="swiper-button-prev swiper-button-prev-ael_gamification-swiper-haircolor"></div>
   <div class="swiper-button-next swiper-button-next-ael_gamification-swiper-haircolor"></div>
</div>


{{#js}}
require(
[
    'jquery',
    'block_ael_gamification/avatar'
],
function(
    $,
    Avatar
) {

    Avatar.initSlider('ael_gamification-swiper-haircolor');
});
{{/js}}


