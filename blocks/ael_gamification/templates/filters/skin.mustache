



<div class="ael_gamification-filter ael_gamification-filter-skin  w-100">
   <div class="swiper ael_gamification_avatar_elements ael_gamification-swiper-skin">
      <div class="swiper-wrapper">
         <!-- Slides -->
         
         <div class="swiper-slide ael_gamification_data_filter" data-value="Tanned">   {{#str}} Tanned, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="Yellow">   {{#str}} Yellow, block_ael_gamification {{/str}} </div>
          <div class="swiper-slide ael_gamification_data_filter" data-value="Pale">   {{#str}} Pale, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="Light">   {{#str}} Light, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="Brown">   {{#str}} Brown, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="DarkBrown">   {{#str}} DarkBrown, block_ael_gamification {{/str}} </div>
         <div class="swiper-slide ael_gamification_data_filter" data-value="Black">   {{#str}} Black, block_ael_gamification {{/str}} </div>
  

       
      </div>
   </div>
   <div class="swiper-button-prev swiper-button-prev-ael_gamification-swiper-skin"></div>
   <div class="swiper-button-next swiper-button-next-ael_gamification-swiper-skin"></div>
</div>


{{#js}}
require(
[
    'jquery',
    'block_ael_gamification/avatar'
],
function(
    $,
    Avatar
) {

    Avatar.initSlider('ael_gamification-swiper-skin');
});
{{/js}}


