{{!
    Page footer.
}}
<footer id="page-footer" class="py-3">
<div class="text-center" style="padding: 20px;"><!-- a href="https://noi.euronics.it">Torna alla Intranet 80.20</a><br><br --!><a href="https://inacademy.euronics.it/lms/annex/Condizioni_uso_portale_Euronics_Academy.pdf">Condizioni generali</a>&nbsp;&nbsp;|&nbsp;&nbsp;<a href="https://noi.euronics.it/termini-di-utilizzo">Informativa privacy</a></div>

	<div class="floating-buttons-wrapper">
                <button id="gotop" class="btn btn-primary btn-floating d-flex" aria-label="Go top" role="button" title="Go top">
                    <span class="edw-icon edw-icon-UpArrow"></span>
                    <span class="btn-floating-text">Go top</span>
                </button>    
     </div>	
    {{# footerdata }}
    <div class="container-fluid">
        <div class="container footer-primary {{#emptyprimary}}d-none{{/emptyprimary}}">
            <div class="row m-0 p-0">
                {{# sections }}
                <div id="footer-column-{{index}}"
                class="{{ classes }} text-xs-center footer-column column-type-{{ type }} {{^visible}}d-none{{/visible}}"
                style="flex: 0 0 {{#width}}{{width}}{{/width}}{{^width}}25{{/width}}%;">
                    <div class="p-2 custom-html {{^hascontent}}invisible{{/hascontent}}">
                        <h4 class="card-title mt-1 font-weight-normal font-size-18">{{{ title }}}</h4>
                        <div class="card-text">{{{ content }}}</div>
                    </div>

                </div>
                {{/ sections }}
            </div>
        </div>

  
        <div id="course-footer">{{{ output.course_footer }}}</div>
        {{{ output.standard_end_of_body_html }}}
    </div>
    {{/ footerdata }}
</footer>
