<style>

	#barrablu {
		width: 320px;
		background-color: #1a408c;
		position: fixed;
		top: 100px;
		left: 0;
		height: 100%;
		z-index: 1000;
		transition: all 0.3s ease-in-out; /* Aggiungi transizione */
		overflow-x: hidden; /* Nasconde il contenuto durante l'animazione */
	}

	#barrablu.chiuso {
		width: 135px;
	}

	.containereur.chiuso {
		padding-left: 135px;
	}

	.iconmenu {
		padding-left: 30px;
		width: 65px;
		height: 33px;
	}


.navbar [data-key="coursecat"] {
    display: none;
}
a#drop-down-catselector-menu {display:none! important;}

.navbar [data-key="home"] {
    display: none;
}
.list-group-item.list-group-item-action.home {display:none! important;}

.navbar [data-key="mycourses"] {
    display: none;
}
.list-group-item.list-group-item-action.mycourses {display:none! important;}

.navbar [data-key="myhome"] {
    display: none;
}
.list-group-item.list-group-item-action.myhome {display:none! important;}

.navbar [title="Dashboard"] {
    display: none;
}
.navbar [title="Catalogo corsi"] {
    display: none;
}
.navbar [title="Gruppi"] {
    display: none;
}
.navbar [title="Intranet"] {
    display: none;
}

  @media (max-width: 1000px) {
    #barrablu {
      display: none !important;
    }
  }

.navbar-brand {
    background-color: #fff;
}

#page {
    background: #F5F8FF;
}
</style>


<body {{{ bodyattributes }}}>

<div id='page-loader-wrapper' style='background:#ffffff;position: fixed;top: 0;left: 0;width: 100%;height: 100%;display: flex;justify-content: center;align-items: center;z-index: 9999;overflow:hidden;'>
    {{#loaderimage}}<img src='{{{loaderimage}}}' alt='loader image' style='width: 50px;height: 50px;'>{{/loaderimage}}
</div>
<script>
    window.addEventListener('load', function (){document.querySelector('#page-loader-wrapper').style.display = 'none';}, false);
    if (localStorage.getItem("nighteyewState") == "1") {
        document.querySelector("#page-loader-wrapper").style.background = "#090909";
    }
</script>

