            "get_compact_logo_url": "http://placekitten.com/50/50",
            "custom_menu": "<li>..</li>",
            "page_heading_menu": "<li>..</li>",
            "search_box": "<div><input type='text'></div>",
            "navbar_plugin_output": "<div class='dropdown'>Messaging</div>",
            "user_menu": "<div class='dropdown'>John Doe</div>"
        },
        "config": {
            "wwwroot": "#",
            "homeurl": "/my/"
        },
        "sitename": "Moodle Site",
        "mobileprimarynav": [
            {
                "text": "Dashboard",
                "url": "/my",
                "isactive": true
            },
            {
                "text": "Site home",
                "url": "/",
                "isactive": false
            },
            {
                "text": "My courses",
                "url": "/course",
                "isactive": false
            }
        ]
    }
}}

<style>

	#barrabluhr {
		width: 320px;
		background-color: #1a408c;
		position: fixed;
		left: 0;
		height: 100px!important;
		z-index: 1000;
		transition: all 0.3s ease-in-out; /* Aggiungi transizione */
		overflow-x: hidden; /* Nasconde il contenuto durante l'animazione */
	}

	#barrabluhr.chiuso {
		width: 135px;
		height: 100px;
	}


.sub-nav {
margin-left: 300px;
height:100px;
}
.sub-nav.chiuso {
margin-left: 135px;
}



  @media (max-width: 1000px) {
    #barrabluhr {
      display: none !important;
    }
	
	.sub-nav.chiuso {
    margin-left: 0px !important;
	}
	
	.sub-nav {
	margin-left: 0px!important;
	}
	
	.containereur.chiuso {
    padding-left: 0px !important;
	}
  }
</style>


<style>

.iconexits {
margin: 50px 0;
}


.iconexit {
background-color: #F1C400;
border: 0;
width: 34px;
cursor: pointer;
position: relative;
}
.iconexit span {
display: block;
height: 2px;
width: 33px;
background-color: transparent;
border-radius: 1px;
position: absolute;

-webkit-transition: -webkit-transform 0.3s;
-webkit-transition: all 300ms ease-in-out;
transition: all 300ms ease-in-out;
}
.iconexit span:first-child {
top: 35px;
}
.iconexit span:nth-child(2) {
top: 49px;
width: 22px;
}
.iconexit span:last-child {
top: 63px;
}
.iconexit--active span:first-child {
-webkit-transform: rotate(45deg);
-ms-transform: rotate(45deg);
transform: rotate(45deg);
position: absolute;
top: 49px;
}
.iconexit--active span:last-child {
-webkit-transform: rotate(-45deg);
-ms-transform: rotate(-45deg);
transform: rotate(-45deg);
position: absolute;
top: 49px;
}
.iconexit--active span:nth-child(2) {
opacity: 0;
}
.iconexit--button {
border-radius: 10px;
}
.iconexit--square {
border-radius: 0;
}
.iconexit--transparent {
background-color: transparent;
}
.iconexit--transparent span {
background-color: #F1C400;
}
.iconexit-transition {
-webkit-transition: -webkit-transform 0.3s;
-webkit-transition: all 300ms ease-in-out;
transition: all 300ms ease-in-out;
}

.userinitials {
    padding: 30px;
	font-size: 20px;
}
</style>


<nav class="navbar fixed-top navbar-expand {{navlayout}}  {{#homepagetransparentheader}}trasnparent-home-nav{{/homepagetransparentheader}}" aria-label="{{#str}}sitemenubar, admin{{/str}}">



		<div data-region="drawer-toggle"  id="barrabluhr" class="d-inline-block m-0 h-100 aprichiudi chiuso">

            <button aria-expanded="{{#navdraweropen}}true{{/navdraweropen}}{{^navdraweropen}}false{{/navdraweropen}}"
            aria-controls="nav-drawer" type="button" class="btn nav-link float-sm-left  bg-transparent h-100 iconexit iconexit--transparent animatedeur rubberBand"
            data-action="toggle-drawer" data-side="left" data-preference="drawer-open-nav" style="margin-left: 35px;">
			<span></span>
			<span></span>
			<span></span>
            </button>

        </div>
		


    <div class="sub-nav chiuso">
        <div class="navbar-toggler-wrapper">
            <button class="navbar-toggler aabtn d-block d-lg-none border-0 h-100 p-0" data-toggler="drawers" data-action="toggle" data-target="theme_remui-drawers-primary">
                <span class="edw-icon edw-icon-Mobile-menu"></span>
                <span class="sr-only">{{#str}}sidepanel, core{{/str}}</span>
            </button>
        </div>
		
       {{#output.get_branding_context}}
            {{#logourl}}
                <img src="{{ logourl }}" class="navbar-brand-logo logo" alt="Euronics Academy">
            {{/logourl}}
        {{/output.get_branding_context}}
		<span style="padding-top: 5px;height: 36px;font-size: 21px;color: #2F2F2F;padding-left: 23px; padding-right: 32px;border-left:1px solid #b5bcc7;" id="titolo">Academy</span>
	
			
        {{#primarymoremenu}}
            <div class="primary-navigation">
                {{> core/moremenu}}
            </div>
        {{/primarymoremenu}}

        <!-- <ul class="navbar-nav d-none d-md-flex my-1 px-1">-->
        <!-- page_heading_menu -->
        <!-- {{{ output.page_heading_menu }}}-->
        <!-- </ul> -->

        <div id="usernavigation" class="navbar-nav ml-auto">
            {{#edwisermenu}}
                <div class="edwiser-navigation">
                    {{> core/moremenu}}
                </div>
            {{/edwisermenu}}
            {{# output.edw_search_box }}
                {{{ output.edw_search_box }}}
            {{/output.edw_search_box}}
            {{#langmenu}}
                {{> theme_remui/language_menu }}
            {{/langmenu}}
            {{{ output.navbar_plugin_output }}}

            {{#usermenu}}
            <div class="d-flex usermenu-wrapper">
                <div class="divider  h-75 align-self-center"></div>
                <div class="d-flex align-items-stretch usermenu-container" data-region="usermenu">
                    {{> core/user_menu }}
                </div>
                {{#isloggedin}}
                <div class="divider  h-75 align-self-center"></div>
                {{/isloggedin}}
            </div>
            {{/usermenu}}

            {{#canenabledm}}
                <div class="nav-darkmode nav-item d-flex align-items-center" data-dm="disabled">
                    <a class="dm-toggle text-decoration-none">
                        {{^dmanimate}}
                        <span class="edw-icon edw-icon-Dark-mode darkmodeicon"  title="{{#str}}darkmodetitilestring, theme_remui{{/str}}"></span>
                        <span class="edw-icon edw-icon-Light-mode lightmodeicon"  title="{{#str}}lightmodetitlestring, theme_remui{{/str}}"></span>
                        {{/dmanimate}}

                        {{#dmanimate}}
                        <img src="{{config.wwwroot}}/theme/remui/pix/darkmode.gif" style="width:50px;height:50px;"/>
                        <span class="edw-icon edw-icon-Light-mode lightmodeicon"  title="{{#str}}lightmodetitlestring, theme_remui{{/str}}"></span>
                        {{/dmanimate}}
                    </a>
                </div>
            {{/canenabledm}}
            {{{ output.edit_switch }}}
        </div>
    </div>

</nav>

{{> theme_remui/primary-drawer-mobile }}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/2.1.3/jquery.min.js"></script>
<script>
var animation = 'rubberBand';
$('.iconexit').on('click', function () {
    $(this).toggleClass('iconexit--active');
    $('#barrablu').toggleClass('chiuso'); // Aggiungi questa riga
	$('.containereur').toggleClass('chiuso');
	$('#barrabluhr').toggleClass('chiuso');
	$('.sub-nav').toggleClass('chiuso');
});
$('.iconexit').on('click', function () {
    $(this).addClass('animatedeur ' + animation).one('webkitAnimationEnd mozAnimationEnd MSAnimationEnd oanimationend animationend', function () {
        $(this).removeClass('animatedeur ' + animation);
    });
});
</script>

